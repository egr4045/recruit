# Database
DATABASE_URL="file:./dev.db"
# For production PostgreSQL:
# DATABASE_URL="postgresql://user:password@host:5432/recruit"

# JWT (generate with: openssl rand -base64 32)
JWT_SECRET="change-this-to-a-random-32-char-secret-key"

# Email (SMTP)
SMTP_HOST="smtp.gmail.com"
SMTP_PORT=587
SMTP_USER="yourmail@gmail.com"
SMTP_PASS="your-app-specific-password"
ADMIN_EMAIL="admin@yourcompany.com"

# Telegram Bot
# 1. Create bot via @BotFather on Telegram (/newbot)
# 2. Add bot to your group/channel
# 3. Get chat_id from https://api.telegram.org/bot<TOKEN>/getUpdates
TELEGRAM_BOT_TOKEN="123456789:AABBccDDeeff..."
TELEGRAM_CHAT_ID="-100123456789"

# App URL
NEXT_PUBLIC_BASE_URL="http://localhost:3000"
