generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  schemas  = ["recruit"]
}

model AdminUser {
  id           Int      @id @default(autoincrement())
  username     String   @unique
  passwordHash String
  createdAt    DateTime @default(now())

  @@schema("recruit")
}

model TimeSlot {
  id          Int          @id @default(autoincrement())
  startsAt    DateTime
  durationMin Int          @default(60)
  isAvailable Boolean      @default(true)
  application Application?
  createdAt   DateTime     @default(now())

  @@index([startsAt])
  @@index([isAvailable])
  @@schema("recruit")
}

model Application {
  id                Int               @id @default(autoincrement())
  slotId            Int               @unique
  slot              TimeSlot          @relation(fields: [slotId], references: [id])
  fullName          String
  email             String?
  phone             String?
  telegram          String?
  position          String
  grade             String
  resumeUrl         String?
  industries        String
  expectedSalary    String?
  painPoints        String
  workFormats       String
  willingToRelocate Boolean           @default(false)
  relocateTo        String?
  strengths         String
  weaknesses        String
  status            ApplicationStatus @default(PENDING)
  paymentLink       String?
  adminNotes        String?
  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt

  candidateProfile CandidateProfile?
  telegramChat     TelegramChat?
  messages         ChatMessage[]

  @@index([status])
  @@index([createdAt])
  @@schema("recruit")
}

enum ApplicationStatus {
  PENDING
  CONFIRMED
  REJECTED
  COMPLETED

  @@schema("recruit")
}

model CandidateProfile {
  id              Int            @id @default(autoincrement())
  applicationId   Int            @unique
  application     Application    @relation(fields: [applicationId], references: [id])
  technicalSkills String?
  softSkills      String?
  languages       String?
  industryExp     String?
  interviewNotes  String?
  overallRating   Int?
  tags            CandidateTag[]
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt

  employerInquiries EmployerInquiry[]

  @@schema("recruit")
}

model CandidateTag {
  id        Int              @id @default(autoincrement())
  tag       String
  category  String           @default("other")
  profileId Int
  profile   CandidateProfile @relation(fields: [profileId], references: [id])

  @@index([tag])
  @@unique([profileId, tag])
  @@schema("recruit")
}

model TelegramChat {
  id               Int         @id @default(autoincrement())
  applicationId    Int         @unique
  application      Application @relation(fields: [applicationId], references: [id])
  telegramChatId   String?
  telegramUsername String
  linkedAt         DateTime?
  createdAt        DateTime    @default(now())

  @@schema("recruit")
}

model ChatMessage {
  id            Int         @id @default(autoincrement())
  applicationId Int
  application   Application @relation(fields: [applicationId], references: [id])
  text          String
  fromAdmin     Boolean     @default(false)
  sentAt        DateTime    @default(now())
  isRead        Boolean     @default(false)

  @@index([applicationId])
  @@schema("recruit")
}

// ─── Employer / Talent Sales ─────────────────────────────────────────────────

model EmployerInquiry {
  id                    Int                   @id @default(autoincrement())
  telegramChatId        String?
  telegramUsername      String
  interestedInProfileId Int?
  interestedIn          CandidateProfile?     @relation(fields: [interestedInProfileId], references: [id])
  status                EmployerInquiryStatus @default(NEW)
  messages              EmployerMessage[]
  access                EmployerAccess?
  createdAt             DateTime              @default(now())
  updatedAt             DateTime              @updatedAt

  @@index([telegramChatId])
  @@schema("recruit")
}

enum EmployerInquiryStatus {
  NEW
  IN_PROGRESS
  GRANTED
  CLOSED

  @@schema("recruit")
}

model EmployerMessage {
  id        Int             @id @default(autoincrement())
  inquiryId Int
  inquiry   EmployerInquiry @relation(fields: [inquiryId], references: [id])
  text      String
  fromAdmin Boolean         @default(false)
  sentAt    DateTime        @default(now())

  @@index([inquiryId])
  @@schema("recruit")
}

model EmployerAccess {
  id         Int             @id @default(autoincrement())
  inquiryId  Int             @unique
  inquiry    EmployerInquiry @relation(fields: [inquiryId], references: [id])
  scope      AccessScope
  profileIds String          @default("[]")
  token      String          @unique @default(cuid())
  createdAt  DateTime        @default(now())

  @@schema("recruit")
}

enum AccessScope {
  ALL
  SELECTED

  @@schema("recruit")
}

model SeoArticle {
  id              Int      @id @default(autoincrement())
  slug            String   @unique
  title           String
  metaDescription String?
  content         String
  isPublished     Boolean  @default(false)
  type            String   @default("ARTICLE")
  views           Int      @default(0)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@schema("recruit")
}
